WRAPPER_PORT=8787
RASPUTIN_LOCALHOST_BYPASS=0

# When the wrapper runs in Docker, 127.0.0.1 means the wrapper container.
# Use host.docker.internal to reach a vLLM server published on the host.
MAIN_VLLM_BASE_URL=http://host.docker.internal:8000/v1

# Optional external API providers. Prefer env vars for repeatable setups.
# Remote models still require Safety -> Privacy lock off and Remote models on.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
